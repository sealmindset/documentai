generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// RBAC: ROLES & PERMISSIONS
// ============================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // ADMIN, ANALYST, VIEWER, VENDOR
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users           User[]
  rolePermissions RolePermission[]
  creator         User?            @relation("RoleCreator", fields: [createdBy], references: [id])

  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  resource    String // e.g., "clients", "issues", "users"
  action      String // "view", "create", "edit", "delete"
  description String?

  // Relations
  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  oidcSubject String?   @unique // OIDC "sub" claim for SSO matching
  roleId      String
  department  String?
  isActive    Boolean   @default(true)
  lastLogin   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  role         Role         @relation(fields: [roleId], references: [id])
  auditTrails  AuditTrail[]
  createdRoles Role[]       @relation("RoleCreator")

  @@map("users")
}

// ============================================
// CLIENT MANAGEMENT
// ============================================

model Client {
  id                  String    @id @default(cuid())
  name                String
  legalName           String?
  dunsNumber          String?
  website             String?
  industry            String?
  country             String?
  stateProvince       String?
  primaryContactName  String?
  primaryContactEmail String?
  primaryContactPhone String?
  businessOwner       String?
  itOwner             String?
  contractStartDate   DateTime?
  contractEndDate     DateTime?
  annualSpend         Decimal?
  status              String    @default("ACTIVE") // ACTIVE, INACTIVE, PENDING, TERMINATED

  // Criminal Defense Case Fields
  caseNumber        String?   // Court case number (e.g., "49D01-2026-F6-012345")
  caseType          String?   // FELONY, MISDEMEANOR, INFRACTION, JUVENILE, FEDERAL
  charges           String?   // JSON array of charge descriptions
  chargeStatutes    String?   // JSON array of statute numbers
  arrestDate        DateTime?
  bondAmount        Decimal?
  bondType          String?   // CASH, SURETY, OWN_RECOGNIZANCE, NO_BOND
  nextHearingDate   DateTime?
  nextHearingType   String?   // INITIAL, PRETRIAL, OMNIBUS, SUPPRESSION, JURY_TRIAL, BENCH_TRIAL, SENTENCING
  trialDate         DateTime?
  disposition       String?   // PENDING, DISMISSED, ACQUITTED, GUILTY_PLEA, GUILTY_VERDICT, DIVERTED
  dispositionDate   DateTime?

  // Court Information
  courtName         String?   // "Marion County Superior Court"
  courtAddress      String?
  courtCounty       String?
  courtDivision     String?   // "Criminal Division 1"
  courtPhone        String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  clientProfiles     ClientProfile[]
  caseReviews        CaseReview[]
  documents          Document[]
  issues             Issue[]
  reports            Report[]
  actionItems        ActionItem[]
  caseContacts       CaseContact[]
  generatedDocuments GeneratedDocument[]
  outboundEmails     OutboundEmail[]
  calendarEvents     CalendarEvent[]

  @@map("clients")
}

// ============================================
// CLIENT PROFILES
// ============================================

model ClientProfile {
  id                   String    @id @default(cuid())
  clientId             String
  priorityTier         String // CRITICAL, HIGH, MEDIUM, LOW
  overallReviewScore   Int? // 1-100
  dataSensitivityLevel String?
  dataTypesAccessed    String? // JSON string array
  systemIntegrations   String? // JSON string array
  hasPiiAccess         Boolean   @default(false)
  hasPhiAccess         Boolean   @default(false)
  hasPciAccess         Boolean   @default(false)
  businessCriticality  String? // MISSION_CRITICAL, BUSINESS_CRITICAL, IMPORTANT, STANDARD
  assessmentFrequency  String?
  lastAssessmentDate   DateTime?
  nextAssessmentDate   DateTime?
  calculatedBy         String? // Agent name (LEXA)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  caseReviews CaseReview[]

  @@map("client_profiles")
}

// ============================================
// CASE REVIEWS
// ============================================

model CaseReview {
  id               String    @id @default(cuid())
  clientId         String
  clientProfileId  String?
  assessmentType   String // INITIAL, ANNUAL, TRIGGERED, RENEWAL
  assessmentStatus String    @default("DRAFT") // DRAFT, IN_PROGRESS, PENDING_REVIEW, COMPLETE, APPROVED
  assessedBy       String? // Agent name (CLARA)
  assessmentDate   DateTime?

  // Review Category Scores (1-5)
  securityScore     Int?
  operationalScore  Int?
  complianceScore   Int?
  financialScore    Int?
  reputationalScore Int?
  strategicScore    Int?

  overallReviewScore Int?
  reviewRating       String? // CRITICAL, HIGH, MEDIUM, LOW
  summary            String?
  recommendations    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientProfile ClientProfile? @relation(fields: [clientProfileId], references: [id])
  issues        Issue[]
  reports       Report[]

  @@map("case_reviews")
}

// ============================================
// DOCUMENTS
// ============================================

model Document {
  id             String    @id @default(cuid())
  clientId       String
  documentType   String // SOC2_TYPE1, SOC2_TYPE2, ISO27001, PENTEST, etc.
  documentName   String
  filePath       String?
  fileSize       Int?
  mimeType       String?
  uploadDate     DateTime  @default(now())
  documentDate   DateTime?
  expirationDate DateTime?
  status         String    @default("PENDING") // PENDING, RECEIVED, ANALYZING, ANALYZED, EXPIRED, REJECTED
  retrievedBy    String? // Agent name (DORA)
  source         String? // Vendor Upload, API, Manual
  version        String?
  isCurrent      Boolean   @default(true)
  analysisResult String?
  createdAt      DateTime  @default(now())

  // Relations
  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  issues Issue[]

  @@map("documents")
}

// ============================================
// ISSUES
// ============================================

model Issue {
  id               String    @id @default(cuid())
  clientId         String
  caseReviewId     String?
  documentId       String?
  issueCode        String? // External issue ID (e.g., AG-2026-001)
  findingType      String?
  findingCategory  String?
  severity         String // CRITICAL, HIGH, MEDIUM, LOW, INFORMATIONAL
  title            String
  description      String?
  recommendation   String?
  snbrRiskMapping  String?
  affectedControls String? // JSON string array
  sourceReference  String?
  identifiedBy     String? // Agent name (ARIA)
  identifiedDate   DateTime  @default(now())
  status           String    @default("OPEN") // OPEN, IN_REMEDIATION, PENDING_VERIFICATION, RESOLVED, ACCEPTED, CLOSED
  dueDate          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  caseReview  CaseReview? @relation(fields: [caseReviewId], references: [id])
  document    Document?   @relation(fields: [documentId], references: [id])
  actionItems ActionItem[]

  @@map("issues")
}

// ============================================
// REPORTS
// ============================================

model Report {
  id            String    @id @default(cuid())
  clientId      String?
  caseReviewId  String?
  reportType    String // EXECUTIVE_SUMMARY, DETAILED_ASSESSMENT, COMPLIANCE_STATUS, etc.
  reportName    String
  generatedBy   String? // Agent name (RITA)
  generatedDate DateTime  @default(now())
  filePath      String?
  content       String?
  status        String    @default("DRAFT") // DRAFT, GENERATED, PENDING_APPROVAL, APPROVED, PUBLISHED
  approvedBy    String?
  approvedDate  DateTime?
  createdAt     DateTime  @default(now())

  // Relations
  client     Client?     @relation(fields: [clientId], references: [id])
  caseReview CaseReview? @relation(fields: [caseReviewId], references: [id])

  @@map("reports")
}

// ============================================
// ACTION ITEMS
// ============================================

model ActionItem {
  id                String    @id @default(cuid())
  issueId           String
  clientId          String
  actionType        String // REMEDIATE, MITIGATE, ACCEPT, TRANSFER
  title             String
  description       String?
  assignedTo        String?
  ownerType         String? // VENDOR, INTERNAL
  priority          String    @default("MEDIUM") // CRITICAL, HIGH, MEDIUM, LOW
  status            String    @default("OPEN") // OPEN, IN_PROGRESS, PENDING_VERIFICATION, VERIFIED, CLOSED, OVERDUE
  dueDate           DateTime?
  completionDate    DateTime?
  managedBy         String? // Agent name (ATLAS)
  verificationNotes String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  issue  Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("action_items")
}

// ============================================
// CONTACTS (many-to-many with cases)
// ============================================

model Contact {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  organization  String?
  title         String?
  streetAddress String?
  city          String?
  state         String?
  zipCode       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  phones       ContactPhone[]
  emails       ContactEmail[]
  caseContacts CaseContact[]

  @@map("contacts")
}

model ContactPhone {
  id        String  @id @default(cuid())
  contactId String
  phone     String
  type      String  @default("BUSINESS") // BUSINESS, HOME, CELLULAR, FAX, COURT
  isPrimary Boolean @default(false)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("contact_phones")
}

model ContactEmail {
  id        String  @id @default(cuid())
  contactId String
  email     String
  type      String  @default("BUSINESS") // BUSINESS, PERSONAL, COURT
  isPrimary Boolean @default(false)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("contact_emails")
}

model CaseContact {
  id        String   @id @default(cuid())
  clientId  String
  contactId String
  role      String // OPPOSING_COUNSEL, PROSECUTOR, CO_COUNSEL, WITNESS, EXPERT_WITNESS, JUDGE, COURT_CLERK, CLIENT, GUARDIAN_AD_LITEM, MEDIATOR, INSURANCE_ADJUSTER
  notes     String?
  createdAt DateTime @default(now())

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([clientId, contactId, role])
  @@map("case_contacts")
}

// ============================================
// AGENT ACTIVITY LOG
// ============================================

model AgentActivityLog {
  id               String   @id @default(cuid())
  agentName        String // LEXA, CLARA, DORA, ARIA, RITA, ATLAS
  activityType     String
  entityType       String?
  entityId         String?
  actionTaken      String?
  inputSummary     String?
  outputSummary    String?
  status           String?
  errorMessage     String?
  processingTimeMs Int?
  createdAt        DateTime @default(now())

  @@index([agentName])
  @@index([createdAt])
  @@map("agent_activity_log")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id                String    @id @default(cuid())
  recipientType     String?
  recipientId       String?
  notificationType  String
  title             String
  message           String?
  relatedEntityType String?
  relatedEntityId   String?
  sentBy            String? // Agent name or System
  sentAt            DateTime?
  readAt            DateTime?
  status            String    @default("PENDING") // PENDING, SENT, READ, FAILED
  createdAt         DateTime  @default(now())

  @@map("notifications")
}

// ============================================
// AUDIT TRAIL
// ============================================

model AuditTrail {
  id         String   @id @default(cuid())
  userId     String?
  agentName  String?
  action     String
  entityType String?
  entityId   String?
  oldValues  String? // JSON string
  newValues  String? // JSON string
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@map("audit_trail")
}

// ============================================
// DOCUMENT TEMPLATES & GENERATION (SAGE)
// ============================================

model DocumentTemplate {
  id             String   @id @default(cuid())
  name           String
  category       String   // PLEADING, CORRESPONDENCE, MOTION, NOTICE, DISCOVERY
  subcategory    String?
  jurisdiction   String?  // "MN", "IN", "Federal"
  courtType      String?  // CIRCUIT, SUPERIOR, DISTRICT, FEDERAL_DISTRICT
  content        String   // Template body with {{placeholders}}
  format         String   @default("DOCX") // DOCX, PDF, TXT
  requiredFields String?  // JSON array of required merge field paths
  isActive       Boolean  @default(true)
  createdBy      String?
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  generatedDocs GeneratedDocument[]

  @@index([category])
  @@map("document_templates")
}

model GeneratedDocument {
  id              String    @id @default(cuid())
  templateId      String
  clientId        String
  documentName    String
  mergeData       String    // JSON of resolved field values
  content         String?   // Generated content (HTML or plain text)
  filePath        String?   // Path to rendered file
  status          String    @default("DRAFT") // DRAFT, PENDING_REVIEW, APPROVED, SENT, FILED
  generatedBy     String?   // "SAGE"
  reviewedBy      String?
  reviewedAt      DateTime?
  sentTo          String?   // Recipient contact ID
  sentAt          DateTime?
  filedAt         DateTime?
  courtCaseNumber String?
  createdAt       DateTime  @default(now())

  template DocumentTemplate @relation(fields: [templateId], references: [id])
  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@map("generated_documents")
}

// ============================================
// OUTBOUND EMAILS (ECHO Agent)
// ============================================

model OutboundEmail {
  id                 String    @id @default(cuid())
  clientId           String
  recipientContactId String?
  recipientEmail     String
  recipientName      String?
  ccEmails           String?   // JSON array
  bccEmails          String?   // JSON array
  subject            String
  body               String
  attachmentIds      String?   // JSON array of GeneratedDocument IDs
  status             String    @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, SENDING, SENT, FAILED
  approvedBy         String?
  approvedAt         DateTime?
  sentAt             DateTime?
  sentBy             String?   // "ECHO"
  messageId          String?   // Graph API message ID for thread tracking
  errorMessage       String?
  triggeredBy        String?   // MANUAL, SAGE_PIPELINE, SCHEDULED
  scheduledFor       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@map("outbound_emails")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  category  String   // COURTESY, DISCOVERY_REQUEST, SCHEDULING, FOLLOW_UP
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

// ============================================
// APPLICATION SETTINGS
// ============================================

model AppSetting {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String?
  groupName       String
  displayName     String
  description     String?
  valueType       String   @default("string") // string, number, boolean, json
  isSensitive     Boolean  @default(false)
  requiresRestart Boolean  @default(false)
  updatedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  auditLogs AppSettingAuditLog[]

  @@map("app_settings")
}

model AppSettingAuditLog {
  id        String   @id @default(cuid())
  settingId String
  oldValue  String?
  newValue  String?
  changedBy String?
  createdAt DateTime @default(now())

  setting AppSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@index([settingId])
  @@map("app_setting_audit_logs")
}

// ============================================
// MANAGED PROMPTS (AI Prompt Management)
// ============================================

model ManagedPrompt {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g., "vera-system", "vera-user-risk-profile"
  name        String // Human-readable name
  description String?
  category    String // "system" | "user" | "template"
  agentName   String? // LEXA, CLARA, DORA, ARIA, RITA, ATLAS
  content     String // Current prompt text
  model       String? // Model tier: complex, standard, simple
  temperature Float?
  maxTokens   Int?
  isActive    Boolean  @default(true)
  status      String   @default("published") // "draft" | "testing" | "published"
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  versions  PromptVersion[]
  auditLogs PromptAuditLog[]

  @@index([agentName])
  @@index([category])
  @@index([status])
  @@map("managed_prompts")
}

model PromptVersion {
  id            String   @id @default(cuid())
  promptId      String
  version       Int
  content       String // Prompt text at this version
  changeSummary String? // What changed and why
  changedBy     String? // User who made the change
  createdAt     DateTime @default(now())

  // Relations
  prompt ManagedPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, version])
  @@index([promptId])
  @@map("prompt_versions")
}

// ============================================
// PROMPT AUDIT LOG (Security Review)
// ============================================

model PromptAuditLog {
  id             String   @id @default(cuid())
  promptId       String
  action         String // "save", "publish", "test", "block"
  riskFlag       Boolean  @default(false) // true = flagged for security review
  warnings       String? // JSON array of warning messages
  blockedReasons String? // JSON array of blocked reasons (if blocked)
  changedBy      String?
  content        String? // Snapshot of content at time of action
  createdAt      DateTime @default(now())

  // Relations
  prompt ManagedPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@index([riskFlag])
  @@index([createdAt])
  @@map("prompt_audit_log")
}

// ============================================
// SHAREPOINT SYNC
// ============================================

model SharePointSync {
  id                String   @id @default(cuid())
  label             String
  siteId            String
  siteName          String
  driveId           String
  driveName         String
  folderPath        String?
  isEnabled         Boolean  @default(true)
  lastSyncAt        DateTime?
  lastSyncStatus    String?  // SYNCING, SUCCESS, PARTIAL, FAILED
  lastSyncError     String?
  lastSyncFileCount Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  files SharePointFile[]

  @@map("sharepoint_syncs")
}

model SharePointFile {
  id               String    @id @default(cuid())
  syncConfigId     String
  sharepointItemId String
  fileName         String
  fileSize         Int
  mimeType         String
  webUrl           String?
  lastModifiedAt   DateTime?
  status           String    @default("PENDING") // PENDING, PROCESSING, PROCESSED, FAILED
  documentId       String?
  processedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime  @default(now())

  syncConfig SharePointSync @relation(fields: [syncConfigId], references: [id], onDelete: Cascade)

  @@unique([syncConfigId, sharepointItemId])
  @@index([syncConfigId])
  @@index([status])
  @@map("sharepoint_files")
}

// ============================================
// CALENDAR EVENTS
// ============================================

model CalendarEvent {
  id              String    @id @default(cuid())
  title           String
  description     String?
  eventType       String    // COURT_DATE, DEADLINE, CLIENT_MEETING, GENERAL
  startAt         DateTime
  endAt           DateTime
  allDay          Boolean   @default(false)
  location        String?
  courtroom       String?
  judge           String?
  clientId        String?
  reminderMinutes Int?
  status          String    @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  color           String?

  // M365 Outlook Sync
  outlookEventId   String?  @unique
  outlookChangeKey String?
  lastSyncedAt     DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([startAt, endAt])
  @@index([clientId])
  @@index([eventType])
  @@map("calendar_events")
}

// ============================================
// BRAIN LAYER: AI MEMORY SYSTEM
// ============================================

model BrainMemory {
  id          String   @id @default(cuid())
  agentName   String?  // Which agent created this (null = user-created)
  entityType  String?  // "Client", "Contact", "Court", etc.
  entityId    String?  // ID of the related entity
  category    String   // "preference", "procedure", "relationship", "fact", "pattern"
  content     String   // The actual memory content
  tags        String   @default("[]") // JSON array of tags for search
  confidence  Float    @default(1.0)  // 0.0–1.0, decays over time
  accessCount Int      @default(0)    // How often this memory has been retrieved
  lastAccessedAt DateTime?
  source      String?  // What triggered this memory (e.g., "ARIA analysis of doc xyz")
  createdBy   String?  // User who created or approved
  isApproved  Boolean  @default(false) // Agent-created memories need approval
  isArchived  Boolean  @default(false)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([agentName])
  @@index([category])
  @@index([isApproved, isArchived])
  @@map("brain_memories")
}
