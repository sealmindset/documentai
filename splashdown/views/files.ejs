<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SplashDown — Document Portal</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen">

  <!-- Header -->
  <header class="bg-white border-b border-slate-200">
    <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-blue-700 rounded-md flex items-center justify-center">
          <span class="text-white text-xs font-bold">SD</span>
        </div>
        <span class="text-slate-400 text-sm">|</span>
        <span class="text-slate-600 text-sm font-medium">SplashDown</span>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-sm text-slate-600"><%= user.name %></span>
        <a href="/portal/auth/logout" class="text-sm text-slate-400 hover:text-slate-600">Sign out</a>
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-6">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-1 text-sm mb-5">
      <% breadcrumb.forEach((crumb, i) => { %>
        <% if (i > 0) { %><span class="text-slate-300 mx-1">/</span><% } %>
        <% if (i === breadcrumb.length - 1) { %>
          <span class="text-slate-900 font-medium"><%= crumb.name %></span>
        <% } else { %>
          <a href="/portal?prefix=<%= encodeURIComponent(crumb.prefix) %>"
             class="text-slate-500 hover:text-blue-600"><%= crumb.name %></a>
        <% } %>
      <% }) %>
    </nav>

    <!-- Actions -->
    <div class="flex flex-wrap items-center gap-3 mb-5">
      <form action="/portal/folder" method="POST" class="flex items-center gap-2">
        <input type="hidden" name="prefix" value="<%= prefix %>">
        <input type="text" name="name" placeholder="New folder name" required
               class="border border-slate-300 rounded-lg px-3 py-2 text-sm w-52 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
        <button type="submit"
                class="bg-slate-100 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-slate-200 transition">
          + Folder
        </button>
      </form>

      <form id="upload-form" action="/portal/upload" method="POST" enctype="multipart/form-data" class="flex items-center">
        <input type="hidden" name="prefix" value="<%= prefix %>">
        <input type="file" name="files" multiple id="file-input" class="hidden"
               onchange="showUploading(); this.form.submit();">
        <button type="button" onclick="document.getElementById('file-input').click()"
                class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition">
          Upload Files
        </button>
      </form>
    </div>

    <!-- File table -->
    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-slate-100 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">
            <th class="px-5 py-3">Name</th>
            <th class="px-5 py-3 w-24">Size</th>
            <th class="px-5 py-3 w-36">Modified</th>
            <th class="px-5 py-3 w-32"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">

          <% if (prefix) { %>
          <tr class="hover:bg-slate-50 transition">
            <td class="px-5 py-3" colspan="4">
              <% const parentParts = prefix.split('/').filter(Boolean).slice(0, -1);
                 const parentPrefix = parentParts.length ? parentParts.join('/') + '/' : ''; %>
              <a href="/portal?prefix=<%= encodeURIComponent(parentPrefix) %>"
                 class="flex items-center gap-2 text-slate-500 hover:text-blue-600 text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Back
              </a>
            </td>
          </tr>
          <% } %>

          <% folders.forEach(folder => { %>
          <tr class="hover:bg-slate-50 transition">
            <td class="px-5 py-3">
              <a href="/portal?prefix=<%= encodeURIComponent(folder.prefix) %>"
                 class="flex items-center gap-3 text-slate-800 hover:text-blue-600 font-medium text-sm">
                <svg class="w-5 h-5 text-amber-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"/>
                </svg>
                <%= folder.name %>
              </a>
            </td>
            <td class="px-5 py-3 text-sm text-slate-400">&mdash;</td>
            <td class="px-5 py-3 text-sm text-slate-400">&mdash;</td>
            <td class="px-5 py-3"></td>
          </tr>
          <% }) %>

          <% files.forEach(file => { %>
          <tr class="hover:bg-slate-50 transition">
            <td class="px-5 py-3">
              <span class="flex items-center gap-3 text-slate-800 text-sm">
                <svg class="w-5 h-5 text-slate-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
                </svg>
                <%= file.name %>
              </span>
            </td>
            <td class="px-5 py-3 text-sm text-slate-500"><%= formatBytes(file.size) %></td>
            <td class="px-5 py-3 text-sm text-slate-500"><%= formatDate(file.lastModified) %></td>
            <td class="px-5 py-3">
              <div class="flex items-center gap-3">
                <a href="/portal/download?key=<%= encodeURIComponent(file.key) %>"
                   class="text-blue-600 hover:text-blue-800 text-sm font-medium">Download</a>
                <form action="/portal/delete" method="POST"
                      onsubmit="return confirm('Delete &quot;<%= file.name %>&quot;?');" class="inline">
                  <input type="hidden" name="key" value="<%= file.key %>">
                  <input type="hidden" name="prefix" value="<%= prefix %>">
                  <button type="submit" class="text-red-400 hover:text-red-600 text-sm">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>

          <% if (!folders.length && !files.length) { %>
          <tr>
            <td class="px-5 py-16 text-center text-slate-400 text-sm" colspan="4">
              No files yet. Upload files or create a folder to get started.
            </td>
          </tr>
          <% } %>

        </tbody>
      </table>
    </div>

    <!-- Drop zone overlay -->
    <div id="dropzone"
         class="hidden fixed inset-0 bg-blue-600/10 z-40 flex items-center justify-center pointer-events-none">
      <div class="bg-white rounded-xl shadow-2xl p-10 text-center border-2 border-dashed border-blue-400">
        <svg class="w-12 h-12 text-blue-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
        </svg>
        <p class="text-slate-600 font-medium">Drop files to upload</p>
      </div>
    </div>

    <!-- Uploading overlay -->
    <div id="uploading"
         class="hidden fixed inset-0 bg-slate-900/50 z-50 flex items-center justify-center">
      <div class="bg-white rounded-xl shadow-2xl p-8 text-center">
        <div class="animate-spin w-8 h-8 border-4 border-blue-600 border-t-transparent rounded-full mx-auto mb-4"></div>
        <p class="text-slate-700 font-medium">Uploading files...</p>
      </div>
    </div>

  </main>

  <script>
    function showUploading() {
      document.getElementById('uploading').classList.remove('hidden');
    }

    let dragCounter = 0;
    const dropzone = document.getElementById('dropzone');

    document.addEventListener('dragenter', (e) => {
      e.preventDefault();
      dragCounter++;
      dropzone.classList.remove('hidden');
    });

    document.addEventListener('dragleave', (e) => {
      e.preventDefault();
      dragCounter--;
      if (dragCounter <= 0) {
        dragCounter = 0;
        dropzone.classList.add('hidden');
      }
    });

    document.addEventListener('dragover', (e) => e.preventDefault());

    document.addEventListener('drop', async (e) => {
      e.preventDefault();
      dragCounter = 0;
      dropzone.classList.add('hidden');

      const files = e.dataTransfer.files;
      if (!files.length) return;

      showUploading();
      const formData = new FormData();
      formData.append('prefix', '<%= prefix %>');
      for (const file of files) {
        formData.append('files', file);
      }
      try {
        await fetch('/portal/upload', { method: 'POST', body: formData });
      } catch (_) {}
      window.location.reload();
    });
  </script>

</body>
</html>
