<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SplashDown — Document Portal</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center">
  <div class="bg-white rounded-xl shadow-lg p-10 max-w-md w-full text-center">
    <div class="mb-6">
      <div class="w-16 h-16 bg-blue-700 rounded-xl flex items-center justify-center mx-auto mb-4">
        <span class="text-white text-xl font-bold">SD</span>
      </div>
      <h1 class="text-2xl font-bold text-slate-900">SplashDown</h1>
      <p class="text-lg text-slate-500 mt-1">Vanmeveren Law Firm &middot; Document Portal</p>
    </div>
    <p class="text-slate-500 mb-8 text-sm leading-relaxed">
      Securely access, upload, and download<br>your legal documents.
    </p>
    <a href="/portal/auth/start"
       class="inline-flex items-center gap-3 bg-slate-800 text-white px-6 py-3 rounded-lg font-medium hover:bg-slate-700 transition">
      <svg class="w-5 h-5" viewBox="0 0 21 21" fill="none">
        <rect x="1" y="1" width="9" height="9" fill="#F25022"/>
        <rect x="11" y="1" width="9" height="9" fill="#7FBA00"/>
        <rect x="1" y="11" width="9" height="9" fill="#00A4EF"/>
        <rect x="11" y="11" width="9" height="9" fill="#FFB900"/>
      </svg>
      Sign in with Microsoft
    </a>
    <p class="text-xs text-slate-400 mt-8">Protected by Microsoft Entra ID</p>
  </div>
</body>
</html>
